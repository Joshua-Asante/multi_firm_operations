//@version=6
indicator("Striker NAS100 v1 — Q-NAS-2 Research Capture", overlay=false,
     max_labels_count=500,
     max_lines_count=50)

// ============================================================================
// PURPOSE — Q-NAS-2 forward-paper instrumentation
// ============================================================================
// Mirrors the locked Striker NAS100 v1 strategy gate logic at
// `strategies/striker/striker_nas100_v1.pine` and emits per-bar research
// telemetry via plot() series so a 4-week TradingView paper run can be
// exported to CSV (right-click chart → Export Chart Data) for the
// gate-conditional analysis the taken-trades log cannot answer.
//
// What this indicator captures per in-session bar:
//   * Each filter's pass/fail (atr_expanding / body_ok / prev_bull /
//     warmup_ok / session_ok / dow_ok / raw_breakout / in_date)
//   * Numeric features (atr_val, atr_ma, atr_exp_ratio, body_ratio,
//     dist_to_res_atr, resistance_lvl)
//   * `is_signal` — the full conjunctive gate (would have fired entry)
//   * `filter_reason_code` — first-blocking-filter code for blocked bars
//   * Lookback 15-bar realized high/low/range (post-factum forward window
//     for any candidate bar reconstructed by date-shift in pandas)
//
// Defaults reproduce v1.0 LOCKED parameter values exactly. Do not change
// defaults without a corresponding strategy-side change. Research mode is
// intended for forward observation only — does not place orders.
//
// Out of scope:
//   * Order placement (this is an indicator, not a strategy).
//   * BE / trail / pyramid post-entry logic — only entry-gate state matters
//     for Q-NAS-2; post-entry behavior is already characterized by the
//     existing trade log.
//   * Backtest replay against pre-2026 data — designed for forward capture
//     under live or replay mode against the chart's NAS100 M15 stream.
//
// CSV export naming convention (target dir: data/tv_exports/pepperstone/):
//   Striker_NAS100_v1research_PEPPERSTONE_NAS100_<YYYY-MM-DD>_<hash>.csv
//
// See `docs/striker_nas100/q_nas_2_capture_plan.md` for the 4-week run plan.

// ============================================================================
// STRATEGY-PARITY INPUTS (defaults match LOCKED v1.0)
// ============================================================================
group_filters = "═══ ENTRY FILTERS (parity with locked strategy) ═══"
breakoutBars  = input.int(15,    "Lookback Bars",       minval=5,   maxval=40,  group=group_filters)
atrLength     = input.int(11,    "ATR Length",          minval=5,   maxval=30,  group=group_filters)
atrMaLength   = input.int(85,    "ATR MA Length",       minval=20,  maxval=100, group=group_filters)
atrExpansion  = input.float(0.28,"ATR Expansion Ratio", minval=0.05,maxval=1.5, step=0.01, group=group_filters)
minBodyRatio  = input.float(0.38,"Min Body Ratio",      minval=0.0, maxval=0.9, step=0.01, group=group_filters)

group_dow = "═══ DAY OF WEEK (parity) ═══"
allowMon = input.bool(true,  "Allow Monday",    group=group_dow)
allowTue = input.bool(true,  "Allow Tuesday",   group=group_dow)
allowWed = input.bool(false, "Allow Wednesday", group=group_dow)
allowThu = input.bool(false, "Allow Thursday",  group=group_dow)
allowFri = input.bool(false, "Allow Friday",    group=group_dow)

group_dates  = "═══ DATE RANGE ═══"
startDate    = input.time(timestamp("2026-05-05"), "Start (forward capture begins)", group=group_dates)
endDate      = input.time(timestamp("2027-12-31"), "End",                            group=group_dates)
inDateRange  = time >= startDate and time <= endDate

// ============================================================================
// SESSION & WARMUP (mirrors strategy lines 146-171)
// ============================================================================
currentHourUTC    = hour(time, "UTC")
sessionOK         = currentHourUTC >= 13 and currentHourUTC < 17

currentDow        = dayofweek(time, "UTC")
dowOK = (allowMon and currentDow == dayofweek.monday) or
     (allowTue and currentDow == dayofweek.tuesday) or
     (allowWed and currentDow == dayofweek.wednesday) or
     (allowThu and currentDow == dayofweek.thursday) or
     (allowFri and currentDow == dayofweek.friday)

var int barsSinceSessionStart = 0
sessionJustOpened = sessionOK and not (currentHourUTC[1] >= 13 and currentHourUTC[1] < 17)
if sessionJustOpened
    barsSinceSessionStart := 0
if sessionOK
    barsSinceSessionStart := barsSinceSessionStart + 1

warmupOK = barsSinceSessionStart > 3

// ============================================================================
// INDICATORS (mirrors strategy lines 176-181)
// ============================================================================
atrVal       = ta.atr(atrLength)
atrMa        = ta.sma(atrVal, atrMaLength)
atrExpRatio  = atrMa > 0 ? atrVal / atrMa - 1 : 0.0
atrExpanding = atrVal > atrMa * (1 + atrExpansion)

highestHigh   = ta.highest(high, breakoutBars)
resistanceLvl = highestHigh[1]

// ============================================================================
// ENTRY FILTERS (mirrors strategy lines 186-197)
// ============================================================================
candleRange    = high - low
candleBody     = math.abs(close - open)
bodyRatio      = candleRange > 0 ? candleBody / candleRange : 0.0
bodyOK         = bodyRatio >= minBodyRatio
prevBarBullish = close[1] > open[1]
rawBreakout    = close > resistanceLvl
distToRes      = resistanceLvl - close
distToResAtr   = atrVal > 0 ? distToRes / atrVal : na

longSignal = rawBreakout and atrExpanding and sessionOK and warmupOK and dowOK and inDateRange and bodyOK and prevBarBullish

// ============================================================================
// FILTER-REASON CODE (first blocking filter)
//   0 = signal would have fired (all gates pass)
//   1 = inDateRange fail
//   2 = sessionOK fail
//   3 = warmupOK fail
//   4 = dowOK fail
//   5 = atrExpanding fail
//   6 = prevBarBullish fail
//   7 = bodyOK fail
//   8 = rawBreakout fail
//   na = bar excluded from capture (out of session)
// ============================================================================
filterReasonCode = na
if sessionOK and inDateRange  // only emit codes for in-session, in-date bars
    filterReasonCode := longSignal ? 0 :
       not inDateRange    ? 1 :
       not sessionOK      ? 2 :
       not warmupOK       ? 3 :
       not dowOK          ? 4 :
       not atrExpanding   ? 5 :
       not prevBarBullish ? 6 :
       not bodyOK         ? 7 :
       not rawBreakout    ? 8 : 0

// ============================================================================
// LOOKBACK 15-BAR REALIZED WINDOW (forward-window proxy by post-shift)
// At bar T, these series report stats over bars [T-15..T]. To get the FORWARD
// window for any bar T0 (a candidate), pull the value of these series at
// bar T0+15 in post-processing — that equals max/min/range over [T0..T0+15].
// Matches the strategy's maxHoldBars=15 cap.
// ============================================================================
look15High  = ta.highest(high, 16)
look15Low   = ta.lowest(low, 16)
look15Range = look15High - look15Low

// ============================================================================
// CAPTURE GUARD — only emit non-na values for bars that matter
// (in-session AND in-date). All other bars emit na so the export CSV
// stays compact.
// ============================================================================
emit = sessionOK and inDateRange

// ============================================================================
// PLOTS (export targets — TradingView "Export Chart Data" walks all plots)
// ============================================================================
// Filter pass/fail flags as 0/1 numerics
plot(emit ? (sessionOK         ? 1 : 0) : na, "is_session_ok",      display=display.data_window)
plot(emit ? (warmupOK          ? 1 : 0) : na, "is_warmup_ok",       display=display.data_window)
plot(emit ? (dowOK             ? 1 : 0) : na, "is_dow_ok",          display=display.data_window)
plot(emit ? (atrExpanding      ? 1 : 0) : na, "is_atr_expanding",   display=display.data_window)
plot(emit ? (bodyOK            ? 1 : 0) : na, "is_body_ok",         display=display.data_window)
plot(emit ? (prevBarBullish    ? 1 : 0) : na, "is_prev_bar_bull",   display=display.data_window)
plot(emit ? (rawBreakout       ? 1 : 0) : na, "is_raw_breakout",    display=display.data_window)
plot(emit ? (longSignal        ? 1 : 0) : na, "is_signal",          display=display.data_window)
plot(emit ? filterReasonCode      : na,        "filter_reason_code", display=display.data_window)

// Numeric features
plot(emit ? atrVal       : na, "atr_val",          display=display.data_window)
plot(emit ? atrMa        : na, "atr_ma",           display=display.data_window)
plot(emit ? atrExpRatio  : na, "atr_exp_ratio",    display=display.data_window)
plot(emit ? bodyRatio    : na, "body_ratio",       display=display.data_window)
plot(emit ? distToResAtr : na, "dist_to_res_atr",  display=display.data_window)
plot(emit ? resistanceLvl: na, "resistance_lvl",   display=display.data_window)

// 15-bar realized window (post-shift in pandas to get the forward view)
plot(emit ? look15High   : na, "look15_high",  display=display.data_window)
plot(emit ? look15Low    : na, "look15_low",   display=display.data_window)
plot(emit ? look15Range  : na, "look15_range", display=display.data_window)

// ============================================================================
// VISUAL — minimal so chart stays readable during paper run
// ============================================================================
plotshape(emit and longSignal,                          "Signal (would-fire)",   shape.triangleup,   location.bottom, color.lime,   size=size.tiny)
plotshape(emit and not longSignal and rawBreakout,      "Filtered raw-breakout", shape.diamond,      location.bottom, color.orange, size=size.tiny)
plotshape(emit and not longSignal and not rawBreakout,  "In-session bar",        shape.cross,        location.bottom, color.new(color.gray, 70), size=size.tiny)

// ============================================================================
// DASHBOARD — current bar's gate state at a glance
// ============================================================================
if barstate.islast
    var table dash = table.new(position.top_right, 2, 12, bgcolor=color.new(color.black, 80), border_width=1)
    table.cell(dash, 0, 0, "Q-NAS-2 RESEARCH",   bgcolor=color.purple, text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 0, str.tostring(filterReasonCode), bgcolor=color.purple, text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 1, "Session OK",       text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, sessionOK ? "✓" : "✗", text_color=sessionOK ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 2, "Warmup OK",        text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, warmupOK ? "✓" : "✗", text_color=warmupOK ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 3, "DOW OK",           text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, dowOK ? "✓" : "✗", text_color=dowOK ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 4, "ATR Expanding",    text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, atrExpanding ? "✓" : "✗", text_color=atrExpanding ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 5, "ATR Exp Ratio",    text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(atrExpRatio * 100, "#.#") + "%", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 6, "Body OK",          text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, bodyOK ? "✓" : "✗", text_color=bodyOK ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 7, "Body Ratio",       text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, str.tostring(bodyRatio * 100, "#.#") + "%", text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 8, "Prev Bull",        text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, prevBarBullish ? "✓" : "✗", text_color=prevBarBullish ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 9, "Raw Breakout",     text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 9, rawBreakout ? "✓" : "✗", text_color=rawBreakout ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0,10, "Dist→Res (ATR)",   text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1,10, na(distToResAtr) ? "—" : str.tostring(distToResAtr, "#.##"), text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0,11, "Signal (full)",    text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1,11, longSignal ? "FIRE" : "—", text_color=longSignal ? color.lime : color.gray, text_size=size.tiny)
