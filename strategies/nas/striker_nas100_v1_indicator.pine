//@version=6
indicator("Striker NAS100 v1.0 (Signal Indicator)", "Striker NAS100 v1 IND", overlay=true,
     max_labels_count=500,
     max_lines_count=500)

// ============================================================================
// LOCK PROVENANCE — Striker NAS100 v1.0 Indicator (companion to Strategy v1.0)
// ============================================================================
// Mirror of Striker NAS100 v1.0 strategy logic for live execution / signal use.
// Same entry filters, same BE/pyramid/trail/exit logic, same DOW/session gates.
// Tracks position state via var variables (no strategy.* machinery).
// Fires alerts at every state transition for bridge consumption.
//
// PARITY NOTE: backtest performance of this indicator should match the strategy
//   exactly when applied to identical price data. Discrepancies = bug — open an
//   investigation, do not deploy live.
//
// LIVE EXECUTION: alerts include computed entry/stop/TP prices. Bridge layer
//   (Alchemy/DXTrade) is expected to compute final position size from broker
//   equity and the configured risk %. Indicator's size calculation uses the
//   "Account Equity (sizing reference)" input and is informational/display only.
//   Bridge MUST authoritatively size from real-time broker equity.
//
// ALERT FORMAT (2026-05-05 alignment with DJ30 v4.4 indicator conventions):
//   Rich human-readable format (emoji header + ━━━ separators) with a final
//   `BRIDGE:` key=value payload line preserved for parser-side extraction.
//   Bridge regex should target the BRIDGE: line, NOT the visual header.
//
// EXIT DETECTION: indicator detects exits from price action on confirmed bars
//   (low <= stop OR high >= TP OR barsInTrade >= maxHold). Real exits happen
//   broker-side via resting stop/TP orders placed by bridge on entry alert.
//   Indicator's exit detection is internal-state-only — drives next-entry
//   readiness and day-stop accumulation. Trust broker fills as canonical.
//
// SESSION/DOW: same UTC session window (13-17) and Mon+Tue locked DOW set
//   as the strategy. Adjust DOW inputs only for research; reproduce locked
//   DOW set for live deploy.
//
// OPEN QUESTION (Q-NAS-1, 2026-05-05): pyramid leg's exit P&L is computed
//   using base entryPrice, not its own add-bar entry price. DJ30 v4.4 tracks
//   pyrEntryPriceSim separately for correct per-leg P&L. Whether NAS100
//   strategy v1.0 has the same simplification is unverified (Rule 0: read
//   strategy file before changing). Day-stop semantics depend on this.
//   Math left unchanged in this convention-sync — flagged for follow-up.
//
// 2026-05-07 NON-STRATEGY PATCH (no version bump):
//   Added alert() calls for anticipation states (NEAR + APPROACH first-bar
//   transitions). Previously these states only had alertcondition() bindings,
//   which require manual per-alert setup in TradingView and do not fire from
//   the universal "Any alert() function call" subscription. Strategy logic
//   (parameters, locks, signal definitions) UNCHANGED. Visual markers and
//   plot logic UNCHANGED. Only push-alert delivery added. BRIDGE: payload
//   preserved on anticipation alerts (matches entry/exit format).
//
//   Per Core Principle #3 (fxify-challenge): SETUP and PROXIMITY are
//   INFORMATIONAL ONLY — wait for FIRE entry alert before trading.
//
//   Symmetric with Aegis v4.3 2026-04-27 patch.

// ============================================================================
// ACCOUNT & RISK
// ============================================================================
group_acct        = "═══ ACCOUNT & RISK ═══"
acctEquity        = input.float(200000.0, "Account Equity (sizing ref)", minval=1000.0, step=1000.0, group=group_acct,
     tooltip="Used for indicator's display & alert size calculation. Bridge layer should override with real broker equity at execution time. Default = $200K matches FXIFY $200K challenge initial capital.")
riskPerTrade      = input.float(0.40, "Risk Per Trade (%)", minval=0.1, maxval=3.0, step=0.01, group=group_acct,
     tooltip="LOCKED v1.0: 0.40%. Matches strategy. Size = acctEquity × risk% / stopDist (display only — bridge sizes authoritatively).")
strikerDayStopPct = input.float(-1.5, "Day Soft-Stop (% of acct equity)", minval=-10.0, maxval=-0.5, step=0.1, group=group_acct,
     tooltip="LOCKED v1.0: -1.5%. Anchored to acctEquity (ref input above). Halts new entries for the day once tracked day P&L (realized only) crosses threshold. Bridge should ALSO enforce day-stop independently from broker equity — defense-in-depth.")

// ============================================================================
// DATE RANGE
// ============================================================================
group_range = "═══ DATE RANGE ═══"
startDate   = input.time(timestamp("2022-01-01"), "Start Date", group=group_range)
endDate     = input.time(timestamp("2026-12-31"), "End Date",   group=group_range)
inDateRange = time >= startDate and time <= endDate

// ============================================================================
// DAILY CAPS
// ============================================================================
group_caps     = "═══ DAILY CAPS ═══"
maxDailyTrades = input.int(2, "Max Trades Per Day", minval=1, maxval=5, step=1, group=group_caps,
     tooltip="LOCKED v1.0: 2. Pyramid adds do NOT count.")

// ============================================================================
// BREAKOUT
// ============================================================================
group_breakout = "═══ BREAKOUT ═══"
breakoutBars = input.int(15, "Lookback Bars", minval=5, maxval=40, group=group_breakout,
     tooltip="LOCKED v1.0: 15.")
atrLength    = input.int(11, "ATR Length", minval=5, maxval=30, group=group_breakout,
     tooltip="LOCKED v1.0: 11.")
atrMaLength  = input.int(85, "ATR MA Length", minval=20, maxval=100, group=group_breakout,
     tooltip="LOCKED v1.0: 85.")
atrExpansion = input.float(0.28, "ATR Expansion Ratio", minval=0.05, maxval=1.5, step=0.01, group=group_breakout,
     tooltip="LOCKED v1.0: 0.28.")

// ============================================================================
// ENTRY QUALITY
// ============================================================================
group_entry  = "═══ ENTRY QUALITY ═══"
minBodyRatio = input.float(0.38, "Min Body Ratio", minval=0.0, maxval=0.9, step=0.05, group=group_entry,
     tooltip="LOCKED v1.0: 0.38.")

// ============================================================================
// STRATEGY PARAMS (LOCKED v1.0)
// ============================================================================
group_strat    = "═══ STRATEGY PARAMS (LOCKED) ═══"
stopAtr        = input.float(1.20, "Stop Loss (ATR)", minval=0.5, maxval=4.0, step=0.05, group=group_strat,
     tooltip="LOCKED v1.0: 1.20.")
tpAtr          = input.float(9.0,  "Take Profit (ATR)", minval=1.5, maxval=30.0, step=0.5, group=group_strat,
     tooltip="LOCKED v1.0: 9.0.")
beTriggerAtr   = input.float(0.55, "BE Trigger (ATR)", minval=0.05, maxval=2.0, step=0.05, group=group_strat,
     tooltip="LOCKED v1.0: 0.55.")
bePadAtr       = input.float(0.15, "BE Pad (ATR)", minval=0.0, maxval=0.5, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 0.15.")
trailTrigger   = input.float(0.10, "Trail Trigger (ATR)", minval=0.05, maxval=4.0, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 0.10.")
trailDistWide  = input.float(0.80, "Trail Wide (ATR)", minval=0.5, maxval=3.0, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 0.80.")
trailDistTight = input.float(0.90, "Trail Tight (ATR)", minval=0.25, maxval=2.0, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 0.90. Wider than wide-phase by design — trails further from peak after profit threshold.")
trailTightenAt = input.float(1.0,  "Tighten After (ATR)", minval=0.5, maxval=5.0, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 1.0.")
maxHoldBars    = input.int(15, "Max Hold (bars)", minval=5, maxval=100, step=5, group=group_strat,
     tooltip="LOCKED v1.0: 15.")
pyramidTrigger = input.float(1.10, "Pyramid Trigger (ATR)", minval=0.5, maxval=3.0, step=0.01, group=group_strat,
     tooltip="LOCKED v1.0: 1.10.")
pyramidMinBars = input.int(6, "Pyramid Min Bars", minval=1, maxval=12, step=1, group=group_strat,
     tooltip="LOCKED v1.0: 6.")
pyramidSize    = input.float(1000.0, "Pyramid Size (% of base)", minval=25.0, maxval=1000.0, step=25.0, group=group_strat,
     tooltip="LOCKED v1.0: 1000% of initial leg.")

// ============================================================================
// DAY OF WEEK
// ============================================================================
group_dow = "═══ DAY OF WEEK ═══"
allowMon = input.bool(true,  "Allow Monday",    group=group_dow, tooltip="LOCKED v1.0: true.")
allowTue = input.bool(true,  "Allow Tuesday",   group=group_dow, tooltip="LOCKED v1.0: true.")
allowWed = input.bool(false, "Allow Wednesday", group=group_dow, tooltip="LOCKED v1.0: false.")
allowThu = input.bool(false, "Allow Thursday",  group=group_dow, tooltip="LOCKED v1.0: false.")
allowFri = input.bool(false, "Allow Friday",    group=group_dow, tooltip="LOCKED v1.0: false.")

// ============================================================================
// PROXIMITY (ATR)
// ============================================================================
group_prox      = "═══ PROXIMITY (ATR) ═══"
proximityAtr    = input.float(0.50, "Approach Zone (× ATR)",   minval=0.05, maxval=2.0, step=0.05, group=group_prox)
strictProximity = input.float(0.15, "Strict Approach (× ATR)", minval=0.02, maxval=1.0, step=0.01, group=group_prox)

// ============================================================================
// ALERTS
// ============================================================================
group_alerts        = "═══ ALERTS ═══"
alertOnAnticipation = input.bool(true, "Anticipation Alerts (NEAR / APPROACH)",
     group=group_alerts,
     tooltip="Fires push-able alert() when price first enters APPROACH proximity (≤ 0.50 ATR below resistance) or NEAR/STRICT zone (≤ 0.15 ATR — typically 1-2 bars before breakout). SETUP ONLY — informational, not a trade signal. BRIDGE: payload preserved (action=anticipate_*). Use \"Any alert() function call\" subscription to receive on phone/watch.")

// ============================================================================
// VISUALS
// ============================================================================
group_visual      = "═══ VISUALS ═══"
showLevels        = input.bool(true,  "Show Breakout Levels",        group=group_visual)
showZone          = input.bool(true,  "Show Approach Zone",          group=group_visual)
showSignals       = input.bool(true,  "Show Signal Diamonds",        group=group_visual)
showApproach      = input.bool(true,  "Show Approach Circles",       group=group_visual)
showFilteredBreak = input.bool(true,  "Show Filtered Breakouts",     group=group_visual)
showBlocked       = input.bool(false, "Show Blocked Signals (debug)", group=group_visual)
showExits         = input.bool(true,  "Show Exit Markers",           group=group_visual)
showBgColor       = input.bool(true,  "Show Background State",       group=group_visual)
showDashboard     = input.bool(true,  "Show Dashboard",              group=group_visual)
showEntryLevels   = input.bool(true,  "Show Entry/SL/TP Lines",      group=group_visual,
     tooltip="Horizontal lines at entry/SL/TP. SL line updates as BE/trail fires. Cleared on exit.")
showEntryLabel    = input.bool(true,  "Show Entry/Pyramid Labels",   group=group_visual,
     tooltip="Rich labels with E/SL/TP/Size. Persistent across all historical trades.")

// ============================================================================
// SESSION & DAY GATES
// ============================================================================
currentHourUTC = hour(time, "UTC")
sessionOK      = currentHourUTC >= 13 and currentHourUTC < 17

currentDow = dayofweek(time, "UTC")
dowOK = (allowMon and currentDow == dayofweek.monday) or
     (allowTue and currentDow == dayofweek.tuesday) or
     (allowWed and currentDow == dayofweek.wednesday) or
     (allowThu and currentDow == dayofweek.thursday) or
     (allowFri and currentDow == dayofweek.friday)

var int barsSinceSessionStart = 0
sessionJustOpened = sessionOK and not (currentHourUTC[1] >= 13 and currentHourUTC[1] < 17)
if sessionJustOpened
    barsSinceSessionStart := 0
if sessionOK
    barsSinceSessionStart := barsSinceSessionStart + 1

warmupOK = barsSinceSessionStart > 3

// ============================================================================
// CALCULATIONS
// ============================================================================
atrVal       = ta.atr(atrLength)
atrMa        = ta.sma(atrVal, atrMaLength)
atrExpanding = atrVal > atrMa * (1 + atrExpansion)

highestHigh   = ta.highest(high, breakoutBars)
lowestLow     = ta.lowest(low,  breakoutBars)
resistanceLvl = highestHigh[1]

candleRange    = high - low
candleBody     = math.abs(close - open)
bodyRatio      = candleRange > 0 ? candleBody / candleRange : 0.0
bodyOK         = bodyRatio >= minBodyRatio
prevBarBullish = close[1] > open[1]

filtersOK = atrExpanding and sessionOK and warmupOK and dowOK and inDateRange and prevBarBullish

belowRes = close <= resistanceLvl
distRes  = resistanceLvl - close
atrSafe  = not na(atrVal) and atrVal > 0
distAtr  = atrSafe ? distRes / atrVal : 999.0

// ============================================================================
// SIZING (display & alert payload — bridge sizes authoritatively)
// ============================================================================
calcSize(stopDist) =>
    risk = acctEquity * (riskPerTrade / 100)
    stopDist > 0 ? risk / stopDist : 0.0

// ============================================================================
// ENTRY SIGNAL
// ============================================================================
rawBreakout   = close > resistanceLvl
longSignalRaw = rawBreakout and atrExpanding and sessionOK and warmupOK and dowOK and inDateRange and bodyOK and prevBarBullish

// ============================================================================
// POSITION STATE MACHINE
// ============================================================================
var bool  inPosition       = false
var float entryPrice       = na
var float entryAtr         = na
var float tpPrice          = na
var float currentStop      = na
var float trailStop        = na
var bool  trailTightened   = false
var int   barsInTrade      = 0
var float initialSize      = na
var float pyramidSizeAdded = 0.0
var bool  pyramidDone      = false
var bool  beTriggered      = false

// Daily trackers
var int   dailyTradeCount   = 0
var float dayPnlRealized    = 0.0
var bool  strikerHaltedToday = false

// Reset daily on new day
if ta.change(time("D")) != 0
    dailyTradeCount     := 0
    dayPnlRealized      := 0.0
    strikerHaltedToday  := false

// Entry visualization handles (var for line mgmt; labels are permanent — no var)
var line entryLine = na
var line slLine    = na
var line tpLine    = na

// ============================================================================
// EXIT DETECTION (on confirmed bars only, in declared priority order)
// ============================================================================
// IMPORTANT: detected from previous bar's stored stop/TP, evaluated against
// current bar's high/low. State reset happens here so a fresh entry can fire
// on the same bar if signal logic permits (matches DJ30 ordering).

prevInPos  = inPosition[1]
prevStop   = currentStop[1]
prevTP     = tpPrice[1]
prevBars   = nz(barsInTrade[1], 0)

exitByTP      = prevInPos and not na(prevTP)   and high >= prevTP
exitByStop    = prevInPos and not na(prevStop) and low  <= prevStop
exitByMaxHold = prevInPos and (prevBars + 1) >= maxHoldBars
positionExit  = (exitByStop or exitByTP or exitByMaxHold) and barstate.isconfirmed

// Stop has priority over TP if both touched same bar (conservative — matches v1.0 strategy).
// Intermediate vars keep each ternary single-line (Pine v6 line-continuation safety).
beStopName     = currentStop >= entryPrice ? "BE/Trail Stop" : "Stop Loss"
stopReason     = beTriggered ? beStopName : "Stop Loss"
exitReason     = exitByStop ? stopReason : exitByTP ? "Take Profit" : exitByMaxHold ? "Max Hold" : ""
exitPriceFinal = exitByStop ? prevStop : exitByTP ? prevTP : close

if positionExit
    // Realize P&L on both legs (base + pyramid if added).
    // NOTE (Q-NAS-1): pyramid leg uses base entryPrice — known parity question
    // vs DJ30 which tracks pyrEntryPriceSim separately. Math unchanged here
    // pending strategy file inspection.
    legPnl = (exitPriceFinal - entryPrice) * (initialSize + pyramidSizeAdded)
    dayPnlRealized := dayPnlRealized + legPnl

    // Latch halt if day P&L crossed soft-stop threshold post-realization
    if not strikerHaltedToday and dayPnlRealized <= acctEquity * strikerDayStopPct / 100
        strikerHaltedToday := true

    // Reset state
    inPosition       := false
    entryPrice       := na
    entryAtr         := na
    tpPrice          := na
    currentStop      := na
    trailStop        := na
    trailTightened   := false
    barsInTrade      := 0
    initialSize      := na
    pyramidSizeAdded := 0.0
    pyramidDone      := false
    beTriggered      := false
    if showEntryLevels
        line.delete(entryLine)
        line.delete(slLine)
        line.delete(tpLine)

// ============================================================================
// ENTRY
// ============================================================================
canTrade     = not inPosition and dailyTradeCount < maxDailyTrades and not strikerHaltedToday
primaryEntry = longSignalRaw and canTrade and barstate.isconfirmed

if primaryEntry
    stopDist = atrVal * stopAtr
    sz       = calcSize(stopDist)

    inPosition       := true
    entryPrice       := close
    entryAtr         := atrVal
    tpPrice          := close + (atrVal * tpAtr)
    currentStop      := close - stopDist
    trailStop        := na
    trailTightened   := false
    barsInTrade      := 0
    initialSize      := sz
    pyramidSizeAdded := 0.0
    pyramidDone      := false
    beTriggered      := false
    dailyTradeCount  := dailyTradeCount + 1

    // --- Entry/SL/TP lines (extend right) ---
    if showEntryLevels
        line.delete(entryLine)
        line.delete(slLine)
        line.delete(tpLine)
        entryLine := line.new(bar_index, close, bar_index + 1, close,
             extend=extend.right, color=color.new(color.blue, 30), width=1, style=line.style_dashed)
        slLine    := line.new(bar_index, currentStop, bar_index + 1, currentStop,
             extend=extend.right, color=color.red, width=2, style=line.style_solid)
        tpLine    := line.new(bar_index, tpPrice, bar_index + 1, tpPrice,
             extend=extend.right, color=color.green, width=2, style=line.style_solid)

    // --- Rich entry label (persistent — not var, all historical labels stay) ---
    if showEntryLabel
        entryInfo = "🟢 LONG\nSize: " + str.tostring(sz, "#.##") + "\nEntry: " + str.tostring(close, format.mintick) + "\nSL: " + str.tostring(currentStop, format.mintick) + "\nTP: " + str.tostring(tpPrice, format.mintick) + "\nRisk: " + str.tostring(riskPerTrade, "#.##") + "%"
        label.new(bar_index, low, entryInfo,
             style=label.style_label_up, color=color.new(color.green, 20),
             textcolor=color.white, size=size.small)

    // --- Rich entry alert (DJ30 visual format + BRIDGE: payload preserved) ---
    entryMsg = "🟢 STRIKER NAS100 LONG\n━━━━━━━━━━━━━━━━━━━━\n📍 ENTRY: " + str.tostring(close, format.mintick) + "\n📊 SIZE_REF: " + str.tostring(sz, "#.##") + "\n🛑 SL: " + str.tostring(currentStop, format.mintick) + "\n🎯 TP: " + str.tostring(tpPrice, format.mintick) + "\n━━━━━━━━━━━━━━━━━━━━\nRisk: " + str.tostring(riskPerTrade, "#.##") + "% | ATR: " + str.tostring(atrVal, "#.#") + "\nBRIDGE: entry=" + str.tostring(close, "#.##") + " stop=" + str.tostring(currentStop, "#.##") + " tp=" + str.tostring(tpPrice, "#.##") + " size_ref=" + str.tostring(sz, "#.##")
    alert(entryMsg, alert.freq_once_per_bar_close)

// ============================================================================
// POSITION MANAGEMENT (BE / Pyramid / Trail — confirmed-bar transitions)
// ============================================================================
pyramidSignal   = false
beFired         = false
trailTightFired = false

if inPosition and not primaryEntry and not na(entryPrice) and not na(entryAtr) and barstate.isconfirmed
    barsInTrade := barsInTrade + 1
    profitAtr   = entryAtr > 0 ? (close - entryPrice) / entryAtr : 0.0
    currentTrailDist = trailTightened ? trailDistTight : trailDistWide

    // Trail tighten flag transition
    if profitAtr >= trailTightenAt and not trailTightened
        trailTightened   := true
        trailTightFired  := true

    // BE ratchet
    if not beTriggered and profitAtr >= beTriggerAtr
        beStop = entryPrice + (entryAtr * bePadAtr)
        currentStop := math.max(currentStop, beStop)
        beTriggered := true
        beFired     := true

    // Pyramid check
    if not pyramidDone and profitAtr >= pyramidTrigger and barsInTrade >= pyramidMinBars
        addSize = initialSize * (pyramidSize / 100)
        pyramidSizeAdded := addSize
        pyramidDone      := true
        pyramidSignal    := true

    // Trail update
    if profitAtr >= trailTrigger
        newTrail = close - (entryAtr * currentTrailDist)
        trailStop   := na(trailStop) ? newTrail : math.max(trailStop, newTrail)
        currentStop := math.max(currentStop, trailStop)

    // Update SL line to reflect current stop (color shifts on BE/trail state)
    if showEntryLevels and not na(slLine)
        line.set_y1(slLine, currentStop)
        line.set_y2(slLine, currentStop)
        slLineColor = trailTightened ? color.orange : beTriggered ? color.yellow : color.red
        line.set_color(slLine, slLineColor)

    // --- Pyramid label ---
    if pyramidSignal and showEntryLabel
        pyrInfo = "🔵 PYR ADD\nSize: +" + str.tostring(pyramidSizeAdded, "#.##") + "\n@ " + str.tostring(close, format.mintick) + "\nStop: " + str.tostring(currentStop, format.mintick) + "\nTP: " + str.tostring(tpPrice, format.mintick)
        label.new(bar_index, low, pyrInfo,
             style=label.style_label_up, color=color.new(color.aqua, 20),
             textcolor=color.white, size=size.small)

    // --- Pyramid alert ---
    if pyramidSignal
        pyrMsg = "🔵 STRIKER NAS100 PYRAMID ADD\n━━━━━━━━━━━━━━━━━━━━\n📍 ADD @ " + str.tostring(close, format.mintick) + "\n📊 SIZE_REF: +" + str.tostring(pyramidSizeAdded, "#.##") + "\n🛑 STOP: " + str.tostring(currentStop, format.mintick) + "\n🎯 TP: " + str.tostring(tpPrice, format.mintick) + "\n━━━━━━━━━━━━━━━━━━━━\nProfit trigger (+" + str.tostring(profitAtr, "#.##") + " ATR)\nBRIDGE: entry=" + str.tostring(close, "#.##") + " stop=" + str.tostring(currentStop, "#.##") + " tp=" + str.tostring(tpPrice, "#.##") + " size_ref=" + str.tostring(pyramidSizeAdded, "#.##")
        alert(pyrMsg, alert.freq_once_per_bar_close)

    // --- BE activation alert (fires once on threshold cross) ---
    if beFired
        beMsg = "🟡 STRIKER NAS100 — BE ACTIVE\n━━━━━━━━━━━━━━━━━━━━\nMove stop to: " + str.tostring(currentStop, format.mintick) + "\nEntry was: " + str.tostring(entryPrice, format.mintick) + "\nPosition is now risk-free\nBRIDGE: action=be_active new_stop=" + str.tostring(currentStop, "#.##")
        alert(beMsg, alert.freq_once_per_bar_close)

    // --- Trail tightened alert (informational) ---
    if trailTightFired
        trailMsg = "🟠 STRIKER NAS100 — TRAIL TIGHTENED\n━━━━━━━━━━━━━━━━━━━━\nProfit: +" + str.tostring(profitAtr, "#.##") + " ATR\nTrail distance: " + str.tostring(trailDistTight, "#.##") + " ATR (was " + str.tostring(trailDistWide, "#.##") + ")\nBRIDGE: action=trail_tight"
        alert(trailMsg, alert.freq_once_per_bar_close)

// ============================================================================
// DERIVED SIGNALS FOR MARKERS
// ============================================================================
longSignal       = primaryEntry
blockedSignal    = longSignalRaw and not inPosition and (dailyTradeCount >= maxDailyTrades or strikerHaltedToday)
filteredBreakout = rawBreakout and not longSignalRaw and inDateRange
approachZone     = filtersOK and belowRes and atrSafe and distAtr <= proximityAtr
strictApproach   = filtersOK and belowRes and atrSafe and distAtr <= strictProximity
strictFirstBar   = strictApproach and not strictApproach[1]
approachFirstBar = approachZone and not approachZone[1]

// ============================================================================
// EXIT ALERT — rich format with reason icon
// ============================================================================
if positionExit
    exitIcon = exitByTP ? "🎯" : exitByStop ? (beTriggered and not na(prevStop) and prevStop >= entryPrice ? "🟡" : "🛑") : "⏱"
    exitMsg  = exitIcon + " STRIKER NAS100 — EXIT (" + exitReason + ")\n━━━━━━━━━━━━━━━━━━━━\nPrice: " + str.tostring(exitPriceFinal, format.mintick) + "\nBRIDGE: action=exit reason=" + exitReason + " price=" + str.tostring(exitPriceFinal, "#.##")
    alert(exitMsg, alert.freq_once_per_bar_close)

// ============================================================================
// DAY-STOP HALT ALERT (fires once on threshold cross)
// ============================================================================
if strikerHaltedToday and not strikerHaltedToday[1]
    haltMsg = "🛑 STRIKER NAS100 — DAY-STOP HIT\n━━━━━━━━━━━━━━━━━━━━\nRealized Day P&L: $" + str.tostring(dayPnlRealized, "#,###") + "\nThreshold: " + str.tostring(strikerDayStopPct, "#.#") + "% of $" + str.tostring(acctEquity, "#,###") + "\nNo new Striker entries today.\nBRIDGE: action=day_stop pnl=" + str.tostring(dayPnlRealized, "#.##")
    alert(haltMsg, alert.freq_once_per_bar_close)

// ============================================================================
// ANTICIPATION ALERTS (SETUP only — informational; NOT a trade signal)
// ============================================================================
// Fires on first-bar entry into proximity zones. Both gated on filtersOK
// (matches the visual approachZone / strictApproach plot logic), so an alert
// only fires when the trade COULD actually trigger if price breaks out.
//
// Per Core Principle #3 (fxify-challenge): SETUP and PROXIMITY are
// informational only. Wait for the FIRE entry alert before trading.
//
// BRIDGE: payload preserved for parser-side extraction (matches entry/exit format).
// Approximate levels assume near-immediate breakout at resistanceLvl.
if alertOnAnticipation and strictFirstBar
    slDistAnt = atrVal * stopAtr
    slApprox  = resistanceLvl - slDistAnt
    tpApprox  = resistanceLvl + atrVal * tpAtr
    sizeAnt   = calcSize(slDistAnt)
    nearMsg   = "🟠 STRIKER NAS100 — NEAR (breakout imminent)\n━━━━━━━━━━━━━━━━━━━━\n⚠️ SETUP ONLY — not a trade signal\nWait for FIRE entry alert before entering.\n━━━━━━━━━━━━━━━━━━━━\n📍 Price: " + str.tostring(close, format.mintick) + "\n📏 Below Res: " + str.tostring(distAtr, "#.##") + " ATR\n🟢 Resistance: " + str.tostring(resistanceLvl, format.mintick) + "\n━━━━━━━━━━━━━━━━━━━━\nApprox levels if breakout fires:\n🛑 SL ~ " + str.tostring(slApprox, format.mintick) + "\n🎯 TP ~ " + str.tostring(tpApprox, format.mintick) + "\n📊 SIZE_REF ~ " + str.tostring(sizeAnt, "#.##") + "\nATR: " + str.tostring(atrVal, "#.#") + "\nBRIDGE: action=anticipate_near entry_approx=" + str.tostring(resistanceLvl, "#.##") + " stop_approx=" + str.tostring(slApprox, "#.##") + " tp_approx=" + str.tostring(tpApprox, "#.##") + " size_ref=" + str.tostring(sizeAnt, "#.##")
    alert(nearMsg, alert.freq_once_per_bar_close)

if alertOnAnticipation and approachFirstBar and not strictApproach
    appMsg = "🟡 STRIKER NAS100 — APPROACH\n━━━━━━━━━━━━━━━━━━━━\n⚠️ SETUP ONLY — not a trade signal\nWatch for breakout. Wait for FIRE alert.\n━━━━━━━━━━━━━━━━━━━━\n📍 Price: " + str.tostring(close, format.mintick) + "\n📏 Below Res: " + str.tostring(distAtr, "#.##") + " ATR\n🟢 Resistance: " + str.tostring(resistanceLvl, format.mintick) + "\nATR: " + str.tostring(atrVal, "#.#") + "\nBRIDGE: action=anticipate_approach price=" + str.tostring(close, "#.##") + " resistance=" + str.tostring(resistanceLvl, "#.##")
    alert(appMsg, alert.freq_once_per_bar_close)

// ============================================================================
// PLOTS
// ============================================================================

plot(showLevels ? highestHigh : na, "Resistance", color.new(color.green, 70), style=plot.style_stepline)
plot(showLevels ? lowestLow   : na, "Support",    color.new(color.red,   70), style=plot.style_stepline)

// Approach zone (fill between resistance and resistance - proximityAtr*ATR)
zoneTop       = showZone ? resistanceLvl : na
zoneBottom    = showZone ? resistanceLvl - (atrVal * proximityAtr) : na
tp_line       = plot(zoneTop,    "Zone Top",    color.new(color.yellow, 100), editable=false)
bp_line       = plot(zoneBottom, "Zone Bottom", color.new(color.yellow, 100), editable=false)
zoneFillColor = filtersOK ? color.new(color.yellow, 85) : color.new(color.gray, 92)
fill(tp_line, bp_line, color=zoneFillColor, title="Approach Zone")

// Approach circles (regular + first-bar strict + sustained strict)
plotshape(showApproach and approachZone and not strictApproach, "Approach",
     shape.circle, location.belowbar, color.new(color.orange, 20), size=size.tiny)

plotshape(showApproach and strictFirstBar, "Strict Approach (first)",
     shape.circle, location.belowbar, color.orange, size=size.small,
     text="NEAR", textcolor=color.orange)

plotshape(showApproach and strictApproach and not strictFirstBar, "Strict Approach (sustained)",
     shape.circle, location.belowbar, color.orange, size=size.small)

// Filtered breakout (raw breakout but failed at least one filter)
plotshape(showFilteredBreak and filteredBreakout, "Filtered Breakout",
     shape.diamond, location.belowbar, color.new(color.green, 75), size=size.tiny,
     text="FILT", textcolor=color.new(color.gray, 30))

// Blocked signal (would-be entry blocked by daily cap or day-stop halt)
plotshape(showBlocked and blockedSignal, "Blocked Signal",
     shape.xcross, location.belowbar, color.new(color.blue, 40), size=size.small,
     text="BLK", textcolor=color.new(color.blue, 30))

// Pyramid marker (no text — label carries it)
plotshape(pyramidSignal, "Pyramid Add",
     shape.triangleup, location.belowbar, color.new(color.aqua, 10), size=size.small)

// Long signal marker (no text — label carries it)
plotshape(showSignals and longSignal, "Long Signal",
     shape.diamond, location.belowbar, color.green, size=size.small)

// Exit flags (TP / STOP / HOLD)
plotshape(showExits and exitByTP, "Exit (TP)",
     shape.flag, location.abovebar, color.new(color.lime, 0), size=size.small,
     text="TP", textcolor=color.white)

plotshape(showExits and exitByStop, "Exit (Stop)",
     shape.flag, location.abovebar, color.new(color.red, 0), size=size.small,
     text="STOP", textcolor=color.white)

plotshape(showExits and exitByMaxHold and not exitByTP and not exitByStop, "Exit (Max Hold)",
     shape.flag, location.abovebar, color.new(color.purple, 0), size=size.small,
     text="HOLD", textcolor=color.white)

// Background state coloring
bgColorWarmup = color.new(color.yellow, 93)
bgColorDow    = color.new(color.red,    95)
bgColorOther  = color.new(color.orange, 95)
bgColorFinal  = not warmupOK ? bgColorWarmup : not dowOK ? bgColorDow : bgColorOther
bgcolor(showBgColor ? bgColorFinal : na, title="State")

// ============================================================================
// DASHBOARD
// ============================================================================

if showDashboard and barstate.islast
    var table dash = table.new(position.top_right, 2, 18,
         bgcolor=color.new(color.black, 85), border_width=1)

    table.cell(dash, 0, 0, "STRIKER NAS100", text_color=color.white, bgcolor=color.orange, text_size=size.small)
    table.cell(dash, 1, 0, "v1.0",           text_color=color.white, bgcolor=color.orange, text_size=size.small)

    dayStr = currentDow == dayofweek.monday ? "MON" : currentDow == dayofweek.tuesday ? "TUE" : currentDow == dayofweek.wednesday ? "WED" : currentDow == dayofweek.thursday ? "THU" : currentDow == dayofweek.friday ? "FRI" : "WKD"
    dayLbl = dayStr + (dowOK ? " ✓" : " ✗")
    table.cell(dash, 0, 1, "Day", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 1, dayLbl, text_color=dowOK ? color.green : color.red, text_size=size.tiny)

    sessLbl = "13-17 UTC" + (sessionOK ? " ✓" : " ✗")
    table.cell(dash, 0, 2, "Session", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 2, sessLbl, text_color=sessionOK ? color.green : color.red, text_size=size.tiny)

    warmLbl = str.tostring(barsSinceSessionStart) + "/3" + (warmupOK ? " ✓" : " ✗")
    table.cell(dash, 0, 3, "Warmup", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 3, warmLbl, text_color=warmupOK ? color.green : color.red, text_size=size.tiny)

    expRatio = atrMa > 0 ? atrVal / atrMa - 1 : 0.0
    expLbl   = str.tostring(expRatio * 100, "#.#") + "%" + (atrExpanding ? " ✓" : " ✗")
    table.cell(dash, 0, 4, "ATR Exp", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 4, expLbl, text_color=atrExpanding ? color.green : color.gray, text_size=size.tiny)

    bodyLbl = str.tostring(bodyRatio * 100, "#.#") + "%" + (bodyOK ? " ✓" : " ✗")
    table.cell(dash, 0, 5, "Body", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 5, bodyLbl, text_color=bodyOK ? color.green : color.gray, text_size=size.tiny)

    table.cell(dash, 0, 6, "Prev Bull", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 6, prevBarBullish ? "YES ✓" : "NO ✗", text_color=prevBarBullish ? color.green : color.red, text_size=size.tiny)

    tradesLbl = str.tostring(dailyTradeCount) + "/" + str.tostring(maxDailyTrades)
    tradesClr = dailyTradeCount < maxDailyTrades ? color.green : color.red
    table.cell(dash, 0, 7, "Trades Today", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 7, tradesLbl, text_color=tradesClr, text_size=size.tiny)

    posText  = inPosition ? (pyramidDone ? "BASE+PYR" : "BASE") : "FLAT"
    posColor = inPosition ? (pyramidDone ? color.aqua : color.green) : color.gray
    table.cell(dash, 0, 8, "Position", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 8, posText, text_color=posColor, text_size=size.tiny)

    sizeText = inPosition and not na(initialSize) ? str.tostring(initialSize, "#.##") + (pyramidDone and pyramidSizeAdded > 0 ? "+" + str.tostring(pyramidSizeAdded, "#.##") : "") : "—"
    table.cell(dash, 0, 9, "Size", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 9, sizeText, text_color=color.white, text_size=size.tiny)

    slDashLbl = beTriggered ? "BE Stop" : "Stop"
    slDashClr = trailTightened ? color.orange : beTriggered ? color.yellow : color.red
    slDashVal = inPosition and not na(currentStop) ? str.tostring(currentStop, format.mintick) : "—"
    table.cell(dash, 0, 10, slDashLbl, text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 10, slDashVal, text_color=slDashClr, text_size=size.tiny)

    tpDashVal = inPosition and not na(tpPrice) ? str.tostring(tpPrice, format.mintick) : "—"
    table.cell(dash, 0, 11, "Take Profit", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 11, tpDashVal, text_color=color.green, text_size=size.tiny)

    barsInLbl = inPosition ? str.tostring(barsInTrade) + "/" + str.tostring(maxHoldBars) : "—"
    table.cell(dash, 0, 12, "Bars In", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 12, barsInLbl, text_color=color.white, text_size=size.tiny)

    distText  = belowRes and atrSafe ? str.tostring(distAtr, "#.##") + " ATR" : "ABOVE"
    distColor = strictApproach ? color.orange : approachZone ? color.yellow : not belowRes ? color.lime : color.gray
    table.cell(dash, 0, 13, "Dist to Res", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 13, distText, text_color=distColor, text_size=size.tiny)

    table.cell(dash, 0, 14, "Acct (ref)", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 14, "$" + str.tostring(acctEquity, "#,###") + " @ " + str.tostring(riskPerTrade, "#.##") + "%", text_color=color.white, text_size=size.tiny)

    dayPnlPrefix = dayPnlRealized >= 0 ? "+$" : "-$"
    dayPnlLbl    = dayPnlPrefix + str.tostring(math.abs(dayPnlRealized), "#,###")
    dayPnlCol    = dayPnlRealized >= 0 ? color.green : color.red
    table.cell(dash, 0, 15, "Day P&L", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 15, dayPnlLbl, text_color=dayPnlCol, text_size=size.tiny)

    dayStopLbl = strikerHaltedToday ? "⛔ HALTED" : "ACTIVE (" + str.tostring(strikerDayStopPct, "#.#") + "%)"
    dayStopCol = strikerHaltedToday ? color.red : color.green
    table.cell(dash, 0, 16, "Day Stop", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 16, dayStopLbl, text_color=dayStopCol, text_size=size.tiny)

    stateText  = longSignal ? "PRIMARY ✓" : pyramidSignal ? "PYRAMID ✓" : blockedSignal ? "BLOCKED" : inPosition ? "IN POSITION (" + str.tostring(barsInTrade) + "b)" : strictApproach ? "STRICT" : approachZone ? "APPROACH" : filteredBreakout ? "FILT" : filtersOK ? "WAITING" : "FILTERED"
    stateColor = longSignal ? color.lime : pyramidSignal ? color.aqua : blockedSignal ? color.blue : inPosition ? color.green : strictApproach ? color.orange : approachZone ? color.yellow : filteredBreakout ? color.orange : filtersOK ? color.aqua : color.gray
    table.cell(dash, 0, 17, "State", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, 17, stateText, text_color=stateColor, text_size=size.tiny)

// ============================================================================
// ALERT CONDITIONS (named fallback — use alert() fn for rich messages)
// ============================================================================

alertcondition(longSignal,                                         title="Striker NAS100 v1 LONG Signal",      message="STRIKER NAS100: Long Entry")
alertcondition(pyramidSignal,                                      title="Striker NAS100 v1 PYRAMID Add",      message="STRIKER NAS100: Pyramid Add")
alertcondition(strikerHaltedToday and not strikerHaltedToday[1],   title="Striker NAS100 v1 DAY-STOP HIT",     message="STRIKER NAS100: Day-stop halt — no new entries today")
alertcondition(exitByTP,                                           title="Striker NAS100 v1 Exit (TP)",        message="STRIKER NAS100: Exit — TP")
alertcondition(exitByStop,                                         title="Striker NAS100 v1 Exit (Stop)",      message="STRIKER NAS100: Exit — Stop")
alertcondition(exitByMaxHold and not exitByTP and not exitByStop,  title="Striker NAS100 v1 Exit (Max Hold)",  message="STRIKER NAS100: Exit — Max Hold")
alertcondition(strictApproach,                                     title="Striker NAS100 v1 Strict Approach",  message="STRIKER NAS100: Breakout imminent")
alertcondition(approachZone,                                       title="Striker NAS100 v1 Approach",         message="STRIKER NAS100: Within proximity")
alertcondition(filteredBreakout,                                   title="Striker NAS100 v1 Filtered Breakout", message="STRIKER NAS100: Raw breakout filtered")
alertcondition(blockedSignal,                                      title="Striker NAS100 v1 Blocked",          message="STRIKER NAS100: Signal blocked (cap or halt)")
