//@version=6
strategy("Striker DJ30 v4.5", overlay=true,
     initial_capital=200000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.cash_per_order,
     commission_value=0,
     slippage=2,
     process_orders_on_close=true,
     calc_on_every_tick=true,
     max_labels_count=500,
     pyramiding=2,
     margin_long=0,
     margin_short=0)

// ============================================================================
// BACKTEST
// ============================================================================
group_backtest = "═══ BACKTEST ═══"
backtestMode = input.bool(true, "Backtest Mode", group=group_backtest,
     tooltip="ON = DD limits disabled, all signals execute across full date range. OFF = Live/Challenge mode with FXIFY DD enforcement.")
startDate   = input.time(timestamp("2022-01-01"), "Start Date", group=group_backtest)
endDate     = input.time(timestamp("2026-04-17"), "End Date",   group=group_backtest)
inDateRange = time >= startDate and time <= endDate

// ============================================================================
// RISK MANAGEMENT (FXIFY)
// ============================================================================
group_risk   = "═══ RISK (FXIFY) ═══"
riskPerTrade = input.float(1.00, "Risk Per Trade (%)", minval=0.1, maxval=3.0, step=0.01, group=group_risk,
     tooltip="LOCKED: 1.00%. Reduced from v4.2's 1.35% for challenge-phase conservatism.")
maxDailyDD   = input.float(1.00, "Max Daily DD (%)",   minval=0.5, maxval=5.0, step=0.1,  group=group_risk,
     tooltip="LOCKED: 1.00%. Tighter intra-day guard rail.")
maxTotalDD   = input.float(4.85, "Max Total DD (%)",   minval=1.0, maxval=5.0, step=0.25, group=group_risk)
maxDailyTrades = input.int(3,    "Max Trades Per Day",  minval=1,  maxval=5,   step=1,    group=group_risk,
     tooltip="LOCKED: 3. Increased from 2 — more reps on a pyramid-dominant edge.")
strikerDayStopPct = input.float(-2, "Day Soft-Stop (% init eq)", minval=-10.0, maxval=-0.5, step=0.1, group=group_risk,
     tooltip="PRIMARY bust-risk guardrail. Halts new Striker entries for the rest of the day once realized day P&L drops to this % of initial equity. At $200K init, -3.5% = -$7K. Pyramid-reversal daily-DD tail mitigation.")

// ============================================================================
// BREAKOUT
// ============================================================================
group_breakout = "═══ BREAKOUT ═══"
breakoutBars   = input.int(15,    "Lookback Bars",       minval=5,   maxval=40,  group=group_breakout,
     tooltip="LOCKED: 15.")
atrLength      = input.int(11,    "ATR Length",          minval=5,   maxval=30,  group=group_breakout)
atrMaLength    = input.int(85,    "ATR MA Length",       minval=20,  maxval=100, group=group_breakout)
atrExpansion   = input.float(0.28, "ATR Expansion Ratio", minval=0.05, maxval=1.5, step=0.01, group=group_breakout)

// ============================================================================
// ENTRY QUALITY
// ============================================================================
group_entry    = "═══ ENTRY QUALITY ═══"
minBodyRatio   = input.float(0.38, "Min Body Ratio", minval=0.0, maxval=0.9, step=0.05, group=group_entry)

// ============================================================================
// EXITS
// ============================================================================
group_exit = "═══ EXITS ═══"
stopAtr    = input.float(1.2, "Stop Loss (ATR)",   minval=0.5, maxval=4.0,  step=0.05, group=group_exit,
     tooltip="LOCKED: 1.2.")
tpAtr      = input.float(8.5,  "Take Profit (ATR)", minval=1.5, maxval=30.0, step=0.5,  group=group_exit,
     tooltip="LOCKED: 8.5.")

// ============================================================================
// BREAKEVEN
// ============================================================================
group_be       = "═══ BREAKEVEN ═══"
beTriggerAtr   = input.float(0.15, "BE Trigger (ATR)", minval=0.05, maxval=2.0, step=0.05, group=group_be,
     tooltip="LOCKED: 0.15. Slightly wider than v4.2's 0.10 to give pyramid setups room to breathe.")
bePadAtr       = input.float(0.05, "BE Pad (ATR)",     minval=0.0,  maxval=0.3, step=0.01, group=group_be)

// ============================================================================
// ADAPTIVE TRAIL
// ============================================================================
group_trail    = "═══ ADAPTIVE TRAIL ═══"
trailTrigger   = input.float(0.15, "Trail Trigger (ATR)",        minval=0.1, maxval=4.0, step=0.01, group=group_trail,
     tooltip="LOCKED: 0.15.")
trailDistWide  = input.float(0.90, "Trail Wide (ATR)",           minval=0.5, maxval=3.0, step=0.01, group=group_trail,
     tooltip="LOCKED: 0.90.")
trailDistTight = input.float(0.8, "Trail Tight (ATR)",          minval=0.25, maxval=2.0, step=0.01, group=group_trail)
trailTightenAt = input.float(1,  "Tighten After (ATR profit)", minval=0.5, maxval=5.0, step=0.01, group=group_trail)

// ============================================================================
// MAX HOLD
// ============================================================================
group_maxhold  = "═══ MAX HOLD ═══"
maxHoldBars    = input.int(55, "Max Hold (bars)", minval=5, maxval=100, step=5, group=group_maxhold,
     tooltip="LOCKED: 55. Restored from v4.2's 30 to let amplified-pyramid trades breathe.")

// ============================================================================
// PYRAMIDING
// ============================================================================
group_pyramid  = "═══ PYRAMIDING ═══"
pyramidTrigger = input.float(1.29,  "Trigger (ATR profit)", minval=0.5,  maxval=3.0,   step=0.01,  group=group_pyramid,
     tooltip="Unchanged. Pyramid triggers at 1.29 ATR profit after min bars met. Pyramid cohort is 94.7% WR across 4yr (87-100% YoY).")
pyramidSize    = input.float(350.0, "Size (%)",             minval=25.0, maxval=1000.0, step=25.0, group=group_pyramid,
     tooltip="LOCKED: 350%. Amplified from v4.2's 250%. This is the entire structural edge.")
pyramidMinBars = input.int(6,       "Min Bars",             minval=1,    maxval=12,    step=1,    group=group_pyramid,
     tooltip="LOCKED: 6.")

// ============================================================================
// SESSION & DAY
// ============================================================================
currentHourUTC = hour(time, "UTC")
sessionOK      = currentHourUTC >= 13 and currentHourUTC < 17

currentDow     = dayofweek(time, "UTC")
dowOK          = currentDow == dayofweek.tuesday or currentDow == dayofweek.friday

var int barsSinceSessionStart = 0
sessionJustOpened = sessionOK and not (currentHourUTC[1] >= 13 and currentHourUTC[1] < 17)
if sessionJustOpened
    barsSinceSessionStart := 0
if sessionOK
    barsSinceSessionStart := barsSinceSessionStart + 1

warmupOK = barsSinceSessionStart > 3

// ============================================================================
// INDICATORS
// ============================================================================
atrVal       = ta.atr(atrLength)
atrMa        = ta.sma(atrVal, atrMaLength)
atrExpanding = atrVal > atrMa * (1 + atrExpansion)

highestHigh = ta.highest(high, breakoutBars)
lowestLow   = ta.lowest(low,  breakoutBars)

// ============================================================================
// ENTRY FILTERS
// ============================================================================
candleRange    = high - low
candleBody     = math.abs(close - open)
bodyRatio      = candleRange > 0 ? candleBody / candleRange : 0
bodyOK         = bodyRatio >= minBodyRatio
prevBarBullish = close[1] > open[1]

// ============================================================================
// ENTRY SIGNAL
// ============================================================================
rawBreakout = close > highestHigh[1]

longSignal = rawBreakout and atrExpanding and sessionOK and warmupOK and dowOK and inDateRange and bodyOK and prevBarBullish

// ============================================================================
// POSITION SIZING
// ============================================================================
calcSize(stopDist) =>
    risk = strategy.equity * (riskPerTrade / 100)
    stopDist > 0 ? risk / stopDist : 0

// ============================================================================
// DRAWDOWN MONITORING
// ============================================================================
currentDD = strategy.equity < strategy.initial_capital ? (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100 : 0

var float dayStart = strategy.initial_capital
if dayofweek != dayofweek[1]
    dayStart := strategy.equity
dailyDD = dayStart > 0 ? (dayStart - strategy.equity) / strategy.initial_capital * 100 : 0

ddHit = not backtestMode and (currentDD >= maxTotalDD or dailyDD >= maxDailyDD)

// ============================================================================
// DAILY TRADE CAP & DAY P&L GUARDRAIL
// ============================================================================
var int dailyTradeCount   = 0
var float strikerDayPnl   = 0.0
var bool strikerHaltedToday = false
var int prevClosedCount   = 0

if ta.change(time("D")) != 0
    dailyTradeCount     := 0
    strikerDayPnl       := 0.0
    strikerHaltedToday  := false

// Accumulate realized day P&L from newly-closed legs.
// Base and pyramid close at the same price but are separate entries — this
// loop captures both cleanly as distinct legs via strategy.closedtrades.profit(i).
if strategy.closedtrades > prevClosedCount
    for i = prevClosedCount to strategy.closedtrades - 1
        strikerDayPnl := strikerDayPnl + strategy.closedtrades.profit(i)
    prevClosedCount := strategy.closedtrades

// Halt trigger: day P&L crosses below the soft-stop threshold (latches for the day).
if not strikerHaltedToday and strikerDayPnl <= strategy.initial_capital * strikerDayStopPct / 100
    strikerHaltedToday := true

canTrade = not ddHit and strategy.opentrades == 0 and dailyTradeCount < maxDailyTrades and not strikerHaltedToday

// ============================================================================
// TRADE STATE
// ============================================================================
var float entryPrice     = na
var float entryAtr       = na
var float tpPrice        = na
var float currentStop    = na
var float trailStop      = na
var bool  trailTightened = false
var int   barsInTrade    = 0
var float initialSize    = na
var int   pyramidCount   = 0
var bool  pyramidDone    = false
var bool  beTriggered    = false

// ============================================================================
// RESET ON FLAT
// ============================================================================
if strategy.position_size == 0 and strategy.position_size[1] != 0
    entryPrice     := na
    entryAtr       := na
    tpPrice        := na
    currentStop    := na
    trailStop      := na
    trailTightened := false
    barsInTrade    := 0
    initialSize    := na
    pyramidCount   := 0
    pyramidDone    := false
    beTriggered    := false

// ============================================================================
// LONG ENTRY
// ============================================================================
if longSignal and canTrade
    stopDist = atrVal * stopAtr
    size     = calcSize(stopDist)

    strategy.entry("Long", strategy.long, qty=size)

    entryPrice     := close
    entryAtr       := atrVal
    tpPrice        := close + (atrVal * tpAtr)
    currentStop    := close - stopDist
    trailStop      := na
    trailTightened := false
    barsInTrade    := 0
    initialSize    := size
    pyramidCount   := 0
    pyramidDone    := false
    beTriggered    := false
    dailyTradeCount := dailyTradeCount + 1

// ============================================================================
// BARS IN TRADE
// ============================================================================
if strategy.position_size != 0
    barsInTrade := barsInTrade + 1

// ============================================================================
// POSITION MANAGEMENT
// ============================================================================
if strategy.position_size > 0 and not na(entryPrice) and not na(entryAtr)
    profit    = close - entryPrice
    profitAtr = profit / entryAtr
    currentTrailDist = trailTightened ? trailDistTight : trailDistWide

    // Tighten trail
    if profitAtr >= trailTightenAt and not trailTightened
        trailTightened := true

    // Breakeven stop
    if not beTriggered and profitAtr >= beTriggerAtr
        beStop = entryPrice + (entryAtr * bePadAtr)
        currentStop := math.max(currentStop, beStop)
        beTriggered := true

    // NOTE: T1 Scale-Out REMOVED in v4.2a. Full base-leg size rides through
    // to pyramid, trail, TP, or max-hold exit. This is the core architectural
    // change that lets the 94.7% pyramid cohort carry more size.

    // Pyramiding — 350% of initial size
    if not pyramidDone and pyramidCount < 1 and profitAtr >= pyramidTrigger and barsInTrade >= pyramidMinBars
        addSize = initialSize * (pyramidSize / 100)
        strategy.entry("Long Add", strategy.long, qty=addSize)
        pyramidCount := pyramidCount + 1
        pyramidDone  := true

    // Trailing stop
    if profitAtr >= trailTrigger
        newStop = close - (entryAtr * currentTrailDist)
        if na(trailStop)
            trailStop := newStop
        else
            trailStop := math.max(trailStop, newStop)
        currentStop := math.max(currentStop, trailStop)

    // Max hold exit
    if barsInTrade >= maxHoldBars
        strategy.close_all("Max Hold")

    // Apply exits
    strategy.exit("Exit Long", "Long", stop=currentStop, limit=tpPrice)
    if pyramidCount > 0
        strategy.exit("Exit Long Add", "Long Add", stop=currentStop, limit=tpPrice)

// DD Close
if ddHit and strategy.position_size != 0
    strategy.close_all("DD Limit")

// ============================================================================
// VISUALS
// ============================================================================
plot(highestHigh, "Resistance", color.new(color.green, 70), style=plot.style_stepline)
plot(lowestLow,   "Support",    color.new(color.red,   70), style=plot.style_stepline)

bgColorWarmup = color.new(color.yellow, 93)
bgColorDow    = color.new(color.red, 95)
bgColorOther  = color.new(color.orange, 95)
bgColorFinal  = not warmupOK ? bgColorWarmup : not dowOK ? bgColorDow : bgColorOther
bgcolor(bgColorFinal)

plotshape(longSignal and canTrade, "Long", shape.diamond, location.belowbar, color.green, size=size.normal)
plotshape(trailTightened != trailTightened[1], "Trail Tight", shape.flag, location.abovebar, color.yellow, size=size.tiny)
plotshape(pyramidDone and pyramidDone != pyramidDone[1], "Pyramid", shape.triangleup, location.belowbar, color.blue, size=size.tiny)
plotshape(beTriggered and beTriggered != beTriggered[1], "BE Hit", shape.circle, location.belowbar, color.aqua, size=size.tiny)

// ============================================================================
// DASHBOARD
// ============================================================================
var table dash = table.new(position.top_right, 2, 18, bgcolor=color.new(color.black, 80), border_width=1)

if barstate.islast
    row = 0

    table.cell(dash, 0, row, "STRIKER DJ30 v4.5", text_color=color.white, bgcolor=color.orange, text_size=size.normal)
    table.merge_cells(dash, 0, row, 1, row)
    row += 1

    modeLbl = backtestMode ? "BACKTEST MODE | DD OFF" : "FXIFY READY | LONG ONLY"
    modeBg  = backtestMode ? color.yellow : color.lime
    table.cell(dash, 0, row, modeLbl, text_color=color.black, bgcolor=modeBg, text_size=size.tiny)
    table.merge_cells(dash, 0, row, 1, row)
    row += 1

    table.cell(dash, 0, row, "Equity", text_color=color.gray, text_size=size.tiny)
    eqCol = strategy.equity >= strategy.initial_capital ? color.green : color.red
    table.cell(dash, 1, row, "$" + str.tostring(strategy.equity, "#,###"), text_color=eqCol, text_size=size.tiny)
    row += 1

    netPct = (strategy.equity - strategy.initial_capital) / strategy.initial_capital * 100
    table.cell(dash, 0, row, "Net P/L", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(netPct, "#.##") + "%", text_color=netPct >= 0 ? color.green : color.red, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Total DD", text_color=color.gray, text_size=size.tiny)
    ddTotalLbl = backtestMode ? str.tostring(currentDD, "#.##") + "% (not enforced)" : str.tostring(currentDD, "#.##") + "% / " + str.tostring(maxTotalDD, "#.##") + "%"
    ddTotalCol = backtestMode ? color.gray : currentDD > maxTotalDD * 0.72 ? color.red : color.green
    table.cell(dash, 1, row, ddTotalLbl, text_color=ddTotalCol, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Daily DD", text_color=color.gray, text_size=size.tiny)
    ddDailyLbl = backtestMode ? str.tostring(dailyDD, "#.##") + "% (not enforced)" : str.tostring(dailyDD, "#.##") + "% / " + str.tostring(maxDailyDD, "#.##") + "%"
    ddDailyCol = backtestMode ? color.gray : dailyDD > maxDailyDD * 0.72 ? color.red : color.green
    table.cell(dash, 1, row, ddDailyLbl, text_color=ddDailyCol, text_size=size.tiny)
    row += 1

    // Day P&L (realized from closed legs only — drives the soft-stop)
    table.cell(dash, 0, row, "Day P&L", text_color=color.gray, text_size=size.tiny)
    dayPnlPrefix = strikerDayPnl >= 0 ? "+$" : "-$"
    dayPnlLbl    = dayPnlPrefix + str.tostring(math.abs(strikerDayPnl), "#,###")
    dayPnlCol    = strikerDayPnl >= 0 ? color.green : color.red
    table.cell(dash, 1, row, dayPnlLbl, text_color=dayPnlCol, text_size=size.tiny)
    row += 1

    // Day soft-stop guardrail status
    table.cell(dash, 0, row, "Day Stop", text_color=color.gray, text_size=size.tiny)
    dayStopLbl = strikerHaltedToday ? "⛔ HALTED" : "ACTIVE (" + str.tostring(strikerDayStopPct, "#.#") + "%)"
    dayStopCol = strikerHaltedToday ? color.red : color.green
    table.cell(dash, 1, row, dayStopLbl, text_color=dayStopCol, text_size=size.tiny)
    row += 1

    wr = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100 : 0
    table.cell(dash, 0, row, "Win Rate", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(wr, "#.#") + "% (" + str.tostring(strategy.wintrades) + "/" + str.tostring(strategy.closedtrades) + ")", text_color=wr >= 50 ? color.green : color.orange, text_size=size.tiny)
    row += 1

    pf = strategy.grossloss != 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : 0
    table.cell(dash, 0, row, "Profit Factor", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(pf, "#.##"), text_color=pf >= 1.5 ? color.green : color.orange, text_size=size.tiny)
    row += 1

    // RF (Recovery Factor) — the metric this build optimizes for
    maxDDUSD = strategy.max_drawdown
    rf = maxDDUSD > 0 ? strategy.netprofit / maxDDUSD : 0
    rfCol = rf >= 15 ? color.lime : rf >= 10 ? color.green : color.orange
    table.cell(dash, 0, row, "RF", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, str.tostring(rf, "#.##"), text_color=rfCol, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Trail", text_color=color.gray, text_size=size.tiny)
    trailLbl = strategy.position_size == 0 ? "—" : trailTightened ? "TIGHT" : "WIDE"
    table.cell(dash, 1, row, trailLbl, text_color=trailTightened ? color.yellow : color.green, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Position", text_color=color.gray, text_size=size.tiny)
    posLbl = strategy.position_size == 0 ? "FLAT" : (pyramidDone ? "BASE+ADD" : "BASE")
    table.cell(dash, 1, row, posLbl, text_color=strategy.position_size > 0 ? color.green : color.gray, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "BE / Pyr", text_color=color.gray, text_size=size.tiny)
    bpLbl = (beTriggered ? "BE✓" : "BE—") + " " + (pyramidDone ? "PYR✓" : "PYR—")
    table.cell(dash, 1, row, bpLbl, text_color=color.aqua, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Bars In", text_color=color.gray, text_size=size.tiny)
    barsInLbl = strategy.position_size == 0 ? "—" : str.tostring(barsInTrade) + " / " + str.tostring(maxHoldBars)
    table.cell(dash, 1, row, barsInLbl, text_color=color.white, text_size=size.tiny)
    row += 1

    dayStr = currentDow == dayofweek.tuesday ? "TUE" : currentDow == dayofweek.friday ? "FRI" : "OFF"
    table.cell(dash, 0, row, "Day", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, dayStr + (dowOK ? " ✓" : " ✗"), text_color=dowOK ? color.green : color.red, text_size=size.tiny)
    row += 1

    table.cell(dash, 0, row, "Session", text_color=color.gray, text_size=size.tiny)
    table.cell(dash, 1, row, "13-17 UTC" + (sessionOK ? " ✓" : " ✗"), text_color=sessionOK ? color.green : color.red, text_size=size.tiny)
    row += 1

    if ddHit
        table.cell(dash, 0, row, "⚠️ DD LIMIT", text_color=color.white, bgcolor=color.red, text_size=size.tiny)
        table.cell(dash, 1, row, "HALTED", text_color=color.white, bgcolor=color.red, text_size=size.tiny)

// ============================================================================
// ALERTS
// ============================================================================
if longSignal and canTrade
    alert("Striker DJ30 v4.5: LONG Entry", alert.freq_once_per_bar)
if ddHit
    alert("Striker DJ30 v4.5: DD LIMIT HIT", alert.freq_once_per_bar)
if trailTightened and not trailTightened[1]
    alert("Striker DJ30 v4.5: Trail tightened", alert.freq_once_per_bar)
if pyramidDone and not pyramidDone[1]
    alert("Striker DJ30 v4.5: Pyramid added", alert.freq_once_per_bar)
if beTriggered and not beTriggered[1]
    alert("Striker DJ30 v4.5: BE stop activated", alert.freq_once_per_bar)
if strikerHaltedToday and not strikerHaltedToday[1]
    alert("🛑 STRIKER DAY-STOP HIT: realized day P&L ≤ " + str.tostring(strikerDayStopPct, "#.#") + "% of initial equity. No new Striker entries today.", alert.freq_once_per_bar)
