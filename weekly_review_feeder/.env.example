# Required for Notion integration (PTL query, Weekly Review create/update)
# Get your token at: https://www.notion.so/my-integrations
# Then share the CTA Track-Record Habits page with the integration
NOTION_API_TOKEN=secret_REPLACE_ME

# Optional path overrides — defaults shown
WRF_FILLS_DIR=data/fills
WRF_BACKTEST_DIR=data/tv_exports/pepperstone
WRF_DD_LOG=data/dd_protection.log
WRF_RUNS_DIR=data/feeder_runs

